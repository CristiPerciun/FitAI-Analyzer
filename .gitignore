**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# API keys (non committare .env)
.env

# Firebase Admin SDK (chiave privata — solo server / secret CI, mai in repo)
**/*firebase-adminsdk*.json
**/*-firebase-adminsdk-*.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
