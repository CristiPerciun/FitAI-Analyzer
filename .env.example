# Copia in .env e inserisci la tua API key (opzionale per sviluppo locale)
# Ottienila da https://aistudio.google.com/apikey
# Su iOS: puoi anche inserire la chiave nell'app (icona chiave in Alimentazione)
GEMINI_API_KEY=INSERISCI_QUI_LA_TUA_GEMINI_API_KEY

# URL del garmin-sync-server (stessa LAN del telefono se il Pi è in casa/hotspot)
# Esempio: http://192.168.1.50:8080 oppure http://172.20.10.4:8080 (hotspot)
GARMIN_SERVER_URL=http://127.0.0.1:8080

# Opzionale: se il garmin-sync-server o un reverse proxy richiede Bearer (es. nginx)
# GARMIN_SERVER_BEARER_TOKEN=
