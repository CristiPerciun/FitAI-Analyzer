# Copia in .env e inserisci la tua API key (opzionale per sviluppo locale)
# Ottienila da https://aistudio.google.com/apikey
# Su iOS: puoi anche inserire la chiave nell'app (icona chiave in Alimentazione)
GEMINI_API_KEY=INSERISCI_QUI_LA_TUA_GEMINI_API_KEY

# URL garmin-sync-server: l'app prova LAN prima, poi REMOTE (auto-detect)
# LAN: quando sei a casa sulla stessa rete del Raspberry
GARMIN_SERVER_URL_LAN=http://192.168.1.200:8080

# REMOTE: quando sei fuori casa (DuckDNS + HTTPS, Nginx proxy)
GARMIN_SERVER_URL_REMOTE=https://myrasberrysyncgar.duckdns.org

# Opzionale: forza un solo URL (disabilita auto-detect LAN/REMOTE).
# NON usare solo l'IP LAN se usi l'app fuori casa: in quel caso lascia questa riga
# commentata cosi l'app prova la LAN e poi usa GARMIN_SERVER_URL_REMOTE (DuckDNS).
# GARMIN_SERVER_URL=http://192.168.1.200:8080

# Opzionale: Bearer token se il server richiede autenticazione
# GARMIN_SERVER_BEARER_TOKEN=
