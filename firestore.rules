rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Token Garmin: lettura/rinnovo SOLO server (Admin SDK, bypassa le regole).
    // Il client puo' SCRIVERE solo il proprio token (login lato client su nativo:
    // GarminService.connectClientSide). Lettura sempre negata al client.
    match /garmin_tokens/{userId} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Token Strava sul server (stesso modello di garmin_tokens).
    match /strava_tokens/{userId} {
      allow read, write: if false;
    }
    // Stato backfill sync: solo lettura client; scrittura solo Admin SDK.
    match /users/{userId}/sync_status/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // Accesso ai dati SOLO se l'UID del documento coincide con l'UID di chi ha fatto il login.
    // Copre: users/{uid}/daily_logs (incl. meals), profile (incl. baseline, diary),
    // rolling_10days, daily_health, activities, ai_current, sync_status, feedback, app_sync.
    // Nessuna regola extra per campi onboarding cibo.
    // daily_health scritto da garmin-sync-server via Admin SDK.
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && !document.matches('sync_status/**');
    }
  }
}
