rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Token Garmin: SOLO server (Admin SDK) puo' leggere/scrivere. Client mai.
    match /garmin_tokens/{userId} {
      allow read, write: if false;
    }
    // Accesso ai dati SOLO se l'UID del documento coincide con l'UID di chi ha fatto il login.
    // Copre: users/{uid}/daily_logs, profile (incl. main_goal, training_goal, nutrition_goal),
    // rolling_10days, baseline_profile, daily_health, meals, activities,
    // longevity_diary, ai_insights. Nessuna regola extra per campi onboarding cibo.
    // daily_health scritto da garmin-sync-server via Admin SDK.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
